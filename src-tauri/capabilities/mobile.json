{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "mobile-capability",
  "description": "Capability for mobile platforms (Android/iOS)",
  "windows": ["main"],
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-confirm",
    "os:allow-platform",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://*" }, { "url": "http://*" }]
    },
    "store:default"
  ]
}
