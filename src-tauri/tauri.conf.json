{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mesh Organiser",
  "version": "2.6.0",
  "identifier": "com.meshorganiser.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev:web",
    "devUrl": "http://127.0.0.1:9435",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Mesh Organiser",
        "width": 1280,
        "height": 800,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src 'self' http://localhost:9435 http://127.0.0.1:9435 ws://127.0.0.1:9435 ws://localhost:9435 ipc: http://ipc.localhost; img-src 'self' https: asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; worker-src 'self' blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$DATA/*", "$DATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBCMEUwQTkwNzE1ODk3NTIKUldSU2wxaHhrQW9PQy93QzdqdnkwQlQ3eXdtOStzUFVoRVh2V280K0VpK2FjZmh6bU16VFZMeHoK",
      "endpoints": [
        "https://github.com/Tanguille/mesh-organiser/releases/latest/download/latest.json"
      ]
    }
  }
}
