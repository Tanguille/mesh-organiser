{
  "name": "mesh-organiser",
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:cleanup && tauri dev",
    "dev:cleanup": "kill-port 9435 && node -e \"setTimeout(() => process.exit(0), 1000)\"",
    "dev:web": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:build": "tauri build --no-sign --config src-tauri/tauri.release-csp.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/ --cache --cache-location .eslintcache",
    "lint:fix": "eslint src/ --cache --cache-location .eslintcache --fix"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "~2.4.7",
    "@tauri-apps/plugin-dialog": "~2.6.0",
    "@tauri-apps/plugin-fs": "~2.4.5",
    "@tauri-apps/plugin-http": "~2.5.7",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "~2.10.0",
    "@threlte/core": "^8.5.0",
    "@threlte/extras": "^9.12.1",
    "@types/qs": "^6.15.0",
    "@types/three": "^0.183.1",
    "base64-js": "^1.5.1",
    "fflate": "^0.8.2",
    "qs": "^6.15.0",
    "three": "0.183.2",
    "threejs-webworker-3mf-loader": "github:manyfold3d/threejs-webworker-3mf-loader"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lucide/svelte": "^0.577.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "autoprefixer": "^10.4.27",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "kill-port": "^2.0.1",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "8.0.2",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "three": "0.183.2"
    }
  }
}
