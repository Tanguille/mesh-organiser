{
  "name": "mesh-organiser",
  "version": "2.7.3",
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:cleanup && tauri dev",
    "dev:cleanup": "kill-port 9435 && node -e \"setTimeout(() => process.exit(0), 1000)\"",
    "dev:web": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --tsgo --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:build": "tauri build --no-sign --config src-tauri/tauri.release-csp.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/ --cache --cache-location .eslintcache",
    "lint:fix": "eslint src/ --cache --cache-location .eslintcache --fix"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "~2.4.9",
    "@tauri-apps/plugin-dialog": "~2.7.1",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-http": "~2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@threlte/core": "^8.5.14",
    "@threlte/extras": "^9.15.1",
    "@types/qs": "^6.15.1",
    "@types/three": "^0.184.1",
    "base64-js": "^1.5.1",
    "fflate": "^0.8.2",
    "qs": "^6.15.1",
    "three": "0.184.0",
    "threejs-webworker-3mf-loader": "github:manyfold3d/threejs-webworker-3mf-loader"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lucide/svelte": "^1.14.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260507.1",
    "autoprefixer": "^10.5.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "kill-port": "^2.0.1",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.59.2",
    "vite": "8.0.11",
    "vitest": "^4.1.5"
  }
}
